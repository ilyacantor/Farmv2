{
  "id": "aam-schema-drift",
  "name": "Schema Drift Handling",
  "description": "Test AAM's ability to detect and adapt to upstream schema changes (field additions, removals, renames).",
  "type": "module",
  "module": "aam",
  "tags": ["medium", "drift", "schema-evolution", "aam-focus"],
  "config": {
    "scale": {
      "sources": 4,
      "records_per_source": 800
    },
    "chaos": {
      "response_chaos": {
        "enabled": true,
        "latency_ms": {
          "p50": 100,
          "p95": 300,
          "p99": 800
        },
        "error_rate_pct": 3,
        "timeout_rate_pct": 1
      },
      "schema_chaos": {
        "enabled": true,
        "field_add_pct": 25,
        "field_remove_pct": 15,
        "field_rename_pct": 10,
        "type_change_pct": 5,
        "nesting_change_pct": 8
      },
      "data_chaos": {
        "enabled": false
      }
    },
    "seed": 45678,
    "synthetic_services": [
      {
        "type": "crm",
        "base_path": "/synthetic/crm"
      },
      {
        "type": "billing",
        "base_path": "/synthetic/billing"
      }
    ],
    "expected_outcomes": {
      "aam": {
        "min_connector_availability_pct": 90,
        "max_error_rate_pct": 8,
        "min_drift_events_detected": 10,
        "drift_handling_success_pct": 85
      }
    }
  }
}
