{
  "id": "dcl-conflict-resolution",
  "name": "Conflict Resolution Test",
  "description": "Test DCL's ability to detect and resolve conflicting customer records from multiple source systems.",
  "type": "module",
  "module": "dcl",
  "tags": ["medium", "conflicts", "data-quality", "dcl-focus"],
  "config": {
    "scale": {
      "sources": 3,
      "customers_per_source": 600,
      "invoices_per_source": 1500
    },
    "chaos": {
      "response_chaos": {
        "enabled": false
      },
      "schema_chaos": {
        "enabled": false
      },
      "data_chaos": {
        "enabled": true,
        "conflicts_pct": 20,
        "missing_values_pct": 8,
        "duplicates_pct": 5,
        "invalid_formats_pct": 3
      }
    },
    "seed": 56789,
    "data_overlaps": {
      "customer_overlap_pct": 50,
      "conflict_rate_pct": 40
    },
    "expected_outcomes": {
      "dcl": {
        "min_mapping_coverage_pct": 82,
        "max_unresolved_conflicts_pct": 12,
        "conflict_resolution_strategy": "most_recent",
        "min_entities_mapped": 500
      }
    }
  }
}
