{
  "id": "dcl-data-quality",
  "name": "Data Quality Handling",
  "description": "Test DCL's handling of poor data quality: missing values, invalid formats, and referential integrity issues.",
  "type": "module",
  "module": "dcl",
  "tags": ["small", "data-quality", "validation", "dcl-focus"],
  "config": {
    "scale": {
      "sources": 2,
      "customers_per_source": 400,
      "subscriptions_per_source": 300,
      "invoices_per_source": 800
    },
    "chaos": {
      "response_chaos": {
        "enabled": false
      },
      "schema_chaos": {
        "enabled": false
      },
      "data_chaos": {
        "enabled": true,
        "missing_values_pct": 18,
        "duplicates_pct": 10,
        "conflicts_pct": 5,
        "invalid_formats_pct": 12,
        "referential_violations_pct": 6
      }
    },
    "seed": 67890,
    "expected_outcomes": {
      "dcl": {
        "min_mapping_coverage_pct": 70,
        "max_unmapped_fields": 80,
        "data_quality_score_min": 65,
        "validation_errors_detected_min": 50
      }
    }
  }
}
