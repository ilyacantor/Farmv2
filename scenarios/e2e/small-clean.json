{
  "id": "e2e-small-clean",
  "name": "Small Clean Enterprise",
  "description": "Baseline E2E test with a small, clean enterprise environment. No chaos, happy path validation.",
  "type": "e2e",
  "tags": ["small", "clean", "baseline", "happy-path"],
  "config": {
    "scale": {
      "assets": {
        "applications": 50,
        "services": 80,
        "databases": 20,
        "hosts": 30
      },
      "business": {
        "organizations": 20,
        "customers": 200,
        "subscriptions": 150,
        "invoices": 500,
        "transactions": 1000,
        "products": 50
      },
      "events": {
        "per_day": 5000,
        "duration_days": 7,
        "types": ["auth", "access", "network", "error"]
      }
    },
    "chaos": {
      "response_chaos": {
        "enabled": false
      },
      "schema_chaos": {
        "enabled": false
      },
      "data_chaos": {
        "enabled": false
      }
    },
    "seed": 12345,
    "synthetic_services": [
      {
        "type": "crm",
        "base_path": "/synthetic/crm"
      },
      {
        "type": "billing",
        "base_path": "/synthetic/billing"
      },
      {
        "type": "assets",
        "base_path": "/synthetic/assets"
      },
      {
        "type": "events",
        "base_path": "/synthetic/events"
      }
    ],
    "expected_outcomes": {
      "aod": {
        "min_assets_discovered": 140,
        "max_errors": 2
      },
      "aam": {
        "min_connector_availability_pct": 98,
        "max_error_rate_pct": 2
      },
      "dcl": {
        "min_mapping_coverage_pct": 95,
        "max_conflicts": 5
      },
      "agents": {
        "min_recommendations": 1
      }
    }
  }
}
