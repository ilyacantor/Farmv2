# AOS-Farm Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Supabase Configuration
# =============================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# For local development with Supabase CLI:
# SUPABASE_URL=http://localhost:54321
# SUPABASE_KEY=your-local-anon-key

# =============================================================================
# autonomOS Service URLs
# =============================================================================

# AOD (Discovery Engine)
AOD_BASE_URL=http://localhost:8001
AOD_API_KEY=your-aod-api-key

# AAM (Adaptive API Mesh)
AAM_BASE_URL=http://localhost:8002
AAM_API_KEY=your-aam-api-key

# DCL (Data Connectivity Layer)
DCL_BASE_URL=http://localhost:8003
DCL_API_KEY=your-dcl-api-key

# Agent Orchestrator
AGENT_ORCH_BASE_URL=http://localhost:8004
AGENT_API_KEY=your-agent-api-key

# =============================================================================
# AOS-Farm Backend Configuration
# =============================================================================

# Server port
FARM_PORT=3001

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log HTTP requests (useful for debugging integration)
LOG_HTTP_REQUESTS=false

# Maximum concurrent runs
MAX_CONCURRENT_RUNS=5

# Default timeout for external service calls (milliseconds)
DEFAULT_TIMEOUT_MS=30000

# =============================================================================
# AOS-Farm Frontend Configuration
# =============================================================================

# Frontend UI port
FARM_UI_PORT=3000

# API base URL (for frontend to call backend)
# In production, this would be your deployed backend URL
VITE_API_BASE_URL=http://localhost:3001
# or for Create React App:
# REACT_APP_API_BASE_URL=http://localhost:3001

# =============================================================================
# Run Configuration
# =============================================================================

# Timeouts for each pipeline stage (milliseconds)
AOD_TIMEOUT_MS=300000        # 5 minutes
AAM_TIMEOUT_MS=600000        # 10 minutes
DCL_TIMEOUT_MS=600000        # 10 minutes
AGENTS_TIMEOUT_MS=600000     # 10 minutes
TOTAL_RUN_TIMEOUT_MS=1800000 # 30 minutes

# Polling interval for checking run status (milliseconds)
STATUS_POLL_INTERVAL_MS=2000

# Retry configuration for external service calls
MAX_RETRIES=3
RETRY_BACKOFF_BASE_MS=1000

# =============================================================================
# Synthetic Data Configuration
# =============================================================================

# Default seed for deterministic data generation
DEFAULT_SEED=12345

# Batch size for bulk inserts
BATCH_INSERT_SIZE=1000

# =============================================================================
# Cleanup Configuration
# =============================================================================

# Auto-cleanup synthetic data after run completion
AUTO_CLEANUP_ENABLED=false

# Retention period for completed runs (days)
RUN_RETENTION_DAYS=30

# Retention period for synthetic data (days)
SYNTHETIC_DATA_RETENTION_DAYS=7

# =============================================================================
# Development / Debug
# =============================================================================

# Enable development mode (more verbose logging, etc.)
DEV_MODE=true

# Enable API request/response logging
DEBUG_API_CALLS=false

# Enable SQL query logging
DEBUG_SQL_QUERIES=false

# =============================================================================
# Optional: Authentication (if implementing auth)
# =============================================================================

# JWT secret for session management
# JWT_SECRET=your-jwt-secret

# Session expiration (seconds)
# SESSION_EXPIRATION_SECONDS=86400

# =============================================================================
# Optional: Monitoring and Observability
# =============================================================================

# Sentry DSN (error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# Datadog API key (metrics and APM)
# DATADOG_API_KEY=your-datadog-api-key

# =============================================================================
# Optional: Feature Flags
# =============================================================================

# Enable WebSocket support for real-time updates
# ENABLE_WEBSOCKETS=false

# Enable webhook notifications
# ENABLE_WEBHOOKS=false

# Webhook URL for run completion notifications
# WEBHOOK_URL=https://your-webhook-url

# =============================================================================
# Production Overrides
# =============================================================================

# In production, override these with actual values:
# - Use service role key for SUPABASE_KEY (not anon key)
# - Use production URLs for all services
# - Set LOG_LEVEL=warn or LOG_LEVEL=error
# - Set DEV_MODE=false
# - Enable monitoring integrations
