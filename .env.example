# =============================================================================
# AOS Farm — Environment Variables
# Copy to .env and fill in values. Secrets go in Render dashboard.
# =============================================================================

# --- Database (one of these is REQUIRED — Farm will not start without it) ---
DATABASE_URL=                          # PostgreSQL connection string
SUPABASE_DB_URL=                       # Alternative: Supabase direct DB URL

# --- AOS Service URLs ---
AOD_BASE_URL=                          # AOD service base URL
AOD_URL=                               # Alias for AOD_BASE_URL (either is accepted)
AOD_SHARED_SECRET=                     # Auth token for AOD requests (x-shared-secret header)
DCL_INGEST_URL=                        # Full DCL ingest endpoint (e.g. https://dcl.../api/dcl/ingest)
DCL_HEALTH_URL=                        # DCL health endpoint
DCL_INGEST_KEY=                        # Auth key for DCL ingest (x-api-key header)
DCL_API_KEY=                           # Alias for DCL_INGEST_KEY
PLATFORM_URL=                          # Platform service URL

# --- Farm identity ---
FARM_URL=                                  # Farm's own public URL
DCL_TENANT_ID=aos-demo                 # Tenant ID sent to DCL on data push
AOD_DISCOVER_URL=                          # AOD discovery endpoint (Render sets this)
SESSION_SECRET=                            # Session signing key

# --- Feature flags ---
BUSINESS_DATA_ENABLED=true
BUSINESS_DATA_TIERS=1,2,3             # Which data tiers to generate (1,2,3 = all)
FARM_ALLOW_DEFAULT_POLICY=false        # Set true only for local dev

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Database pool tuning (optional — sensible defaults built in) ---
# DB_POOL_MIN=1
# DB_POOL_MAX=5
# DB_CONNECT_TIMEOUT=30
# DB_COMMAND_TIMEOUT=30
# DB_STATEMENT_TIMEOUT=30
# DB_MAX_INACTIVE_LIFETIME=30
# DB_BACKOFF_BASE=2
# DB_BACKOFF_CAP=30
# DB_FAIL_THRESHOLD=5
# DB_COOLDOWN_SECONDS=60
# DB_CONCURRENCY=2
# DB_BATCH_SIZE=500
# DB_MAX_RETRIES=3
